{
  "name": "loopbreaker",
  "version": "0.1.0",
  "type": "module",
  "description": "Read-only middleware that detects semantic failures in Claude Code sessions",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit",
    "migrate:op": "node dist/storage/migrate-cli.js op",
    "migrate:eval": "node dist/storage/migrate-cli.js eval"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/chokidar": "^1.7.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.5.0"
  }
}
